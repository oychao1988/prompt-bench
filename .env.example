# ====== PromptBench 配置文件 ======
#
# 这是 PromptBench 的环境变量配置模板
# 复制此文件为 .env 并根据需要填写配置
#
# 使用方式：
# 1. cp .env.example .env
# 2. 编辑 .env 文件，填写必要的配置
# 3. 运行 promptbench evaluate
#
# 注意：.env 文件包含敏感信息，切勿提交到 git

# ====== LLM API 配置 ======
#
# 通用兜底配置（未配置特定 provider 时使用）
# 适用于统一使用同一个 API 网关的场景
# llm_base_url=https://api.openai.com/v1
# llm_api_key=sk-xxx

# 或按 provider 分别配置（推荐）

# OpenAI
# openai_base_url=https://api.openai.com/v1
# openai_api_key=sk-xxx

# Anthropic（若走统一网关可只配上面 llm_*）
# anthropic_base_url=https://api.anthropic.com/v1
# anthropic_api_key=sk-ant-xxx

# Google
# google_base_url=https://generativelanguage.googleapis.com/v1
# google_api_key=xxx

# DeepSeek
# deepseek_base_url=https://api.deepseek.com/v1
# deepseek_api_key=sk-xxx

# ====== AI检测工具配置 ======
# 主要用于中文内容检测，推荐使用朱雀检测（腾讯）

# 1. 朱雀AI检测（腾讯）- 中文检测首选 ⭐⭐⭐⭐⭐
# 申请地址：https://matrix.tencent.com/ai-detect/ai_gen_txt
# 特点：专门针对中文优化，目前特邀测试阶段免费
ZHUQUE_DETECTOR_ENABLED=false
# ZHUQUE_API_KEY=your_api_key
# ZHUQUE_ENDPOINT=https://matrix.tencent.com/ai-detect/ai_gen_txt
# ZHUQUE_WEIGHT=1.0

# 2. GPTZero - 国际通用，中文支持良好 ⭐⭐⭐⭐
# 申请地址：https://gptzero.me/
# 价格：$15-25/月
GPTZERO_DETECTOR_ENABLED=false
# GPTZERO_API_KEY=your_gptzero_api_key
# GPTZERO_ENDPOINT=https://api.gptzero.me/v2/predict/text
# GPTZERO_WEIGHT=0.8

# 3. CopyLeaks - 支持中文 ⭐⭐⭐
COPYLEAKS_DETECTOR_ENABLED=false
# COPYLEAKS_API_KEY=your_copyleaks_api_key
# COPYLEAKS_ENDPOINT=https://api.copyleaks.com
# COPYLEAKS_WEIGHT=0.6

# 4. Originality.ai - 主要针对英文
ORIGINALITY_DETECTOR_ENABLED=false
# ORIGINALITY_API_KEY=your_originality_api_key
# ORIGINALITY_ENDPOINT=https://api.originality.ai
# ORIGINALITY_WEIGHT=0.5

# 5. Writer.com - 主要针对英文
WRITER_DETECTOR_ENABLED=false
# WRITER_API_KEY=your_writer_api_key
# WRITER_ENDPOINT=https://api.writer.com
# WRITER_WEIGHT=0.5

# ====== 推荐配置方案 ======
#
# 方案1：只使用朱雀检测（中文首选）
# ZHUQUE_DETECTOR_ENABLED=true
# ZHUQUE_API_KEY=your_key
#
# 方案2：朱雀 + GPTZero（最准确）
# ZHUQUE_DETECTOR_ENABLED=true
# ZHUQUE_API_KEY=your_key
# ZHUQUE_WEIGHT=0.7
# GPTZERO_DETECTOR_ENABLED=true
# GPTZERO_API_KEY=your_key
# GPTZERO_WEIGHT=0.3
#
# 方案3：只使用GPTZero（无朱雀API时）
# GPTZERO_DETECTOR_ENABLED=true
# GPTZERO_API_KEY=your_key
#
# 方案4：无API密钥（模拟检测，仅供参考）
# 所有检测器保持DISABLED状态

# 提示词自动优化时使用的模型（可选）
# PROMPT_OPTIMIZER_MODEL=gpt-5.4
# PROMPT_OPTIMIZER_PROVIDER=openai

# AI语义评估模型（可选）
# EVALUATION_MODEL=gpt-5.4
# EVALUATION_PROVIDER=openai

# ====== 配置说明 ======
#
# 所有配置都是可选的，系统会在未配置时使用默认值或模拟模式
#
# 最小配置：
# - 无需任何配置即可运行（使用模拟检测和默认模型）
# - 建议至少配置一个 LLM API 以获得真实的评估结果
# - 建议配置至少一个 AI 检测器以获得准确的人类化评分
#
# 配置优先级：
# - 特定 provider 配置 > 通用 llm_* 配置
# - 例如：openai_api_key 会覆盖 llm_api_key（当 provider 为 openai 时）
#
# 模块化架构：
# - PromptBench 2.0 采用模块化架构
# - 所有配置通过 ConfigManager 统一管理
# - 支持多模型并行评估和多检测器聚合
#
# 帮助文档：
# - README.md - 项目概述
# - USAGE.md - 详细使用说明
# - CLAUDE.md - 开发指南